        "uri": "azureml://datastores/workspaceblobstore/paths/smoke/train/"
      },
      "trainingSettings": {
        "enableStackEnsemble": false
      },
      "validationData": {
        "jobInputType": "mltable",
        "uri": "azureml://datastores/workspaceblobstore/paths/smoke/valid/"
      }
