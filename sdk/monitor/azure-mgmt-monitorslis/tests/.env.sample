# Environment variables for SLI live tests
# Copy this to .env and fill in real values for local testing

# Azure credentials (set by DefaultAzureCredential or the test framework)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# SLI test-specific variables (provisioned by test-resources.bicep)
SERVICE_GROUP_NAME=arm-sdk-tests-sg
AMW_RESOURCE_ID=/subscriptions/<SUBSCRIPTION_ID>/resourceGroups/<RESOURCE_GROUP>/providers/microsoft.monitor/accounts/<AMW_ACCOUNT_NAME>
MANAGED_IDENTITY_RESOURCE_ID=/subscriptions/<SUBSCRIPTION_ID>/resourceGroups/<RESOURCE_GROUP>/providers/Microsoft.ManagedIdentity/userAssignedIdentities/<MANAGED_IDENTITY_NAME>
SOURCE_AMW_RESOURCE_ID=/subscriptions/<SUBSCRIPTION_ID>/resourceGroups/<RESOURCE_GROUP>/providers/microsoft.monitor/accounts/<AMW_ACCOUNT_NAME>
SOURCE_MANAGED_IDENTITY_RESOURCE_ID=/subscriptions/<SUBSCRIPTION_ID>/resourceGroups/<RESOURCE_GROUP>/providers/Microsoft.ManagedIdentity/userAssignedIdentities/<MANAGED_IDENTITY_NAME>
